{
  "name": "makdolan-mvp",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:workflows": "node scripts/lint-workflows.mjs",
    "build": "expo export --platform web",
    "build:web": "expo export --platform web",
    "brain:context": "node .ai/brain/scripts/create-context-pack.mjs",
    "brain:index": "node .ai/brain/scripts/create-repo-index.mjs",
    "brain:search": "node .ai/brain/scripts/search-brain.mjs",
    "brain:impact": "node .ai/brain/scripts/analyze-impact.mjs",
    "brain:health": "node .ai/brain/scripts/health-check.mjs",
    "brain:smoke": "node .ai/brain/scripts/smoke-check.mjs",
    "brain:automation:check": "node .ai/brain/scripts/validate-automation-activation.mjs",
    "brain:memory:update": "node .ai/brain/scripts/update-memory.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-status-bar": "~3.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.2",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.15"
  }
}
